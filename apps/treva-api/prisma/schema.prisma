generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  title     String
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]
}

model UnitLayout {
  id                  String      @id @default(cuid())
  title               String
  name                String
  slug                String      @unique
  status              Status      @default(available)
  floor               Int
  number              Int?
  totalArea           Float
  internalArea        Float
  balconyArea         Float?
  prices              Json         @default("{}")
  completionYear      Int
  numberOfFloors      Json
  similarApartmentIds String[]
  mainImage           Json?
  gallery             Json[]
  documents           Json[]
  location            Json?
  categoryId          String
  category            Category    @relation(fields: [categoryId], references: [id])
  roomOptionId        String?
  roomOption          RoomOption? @relation(fields: [roomOptionId], references: [id])
  viewOptionId        String?
  viewOption          ViewOption? @relation(fields: [viewOptionId], references: [id])
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model RoomOption {
  id        String   @id @default(cuid())
  value     String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]
}

model ViewOption {
  id        String       @id @default(cuid())
  value     String       @unique
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  unitLayouts UnitLayout[]
}

model Currency {
  id        String   @id @default(cuid())
  name      String   @unique
  value     String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  available
  sold
  reserved
}
