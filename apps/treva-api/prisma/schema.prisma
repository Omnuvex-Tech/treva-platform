generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id              String   @id @default(cuid())
  title           String
  name            String
  slug            String   @unique
  image           String?
  status          String   @default("active")
  housesCount     Int      @default(0)
  propertiesCount Int      @default(0)
  reservedCount   Int      @default(0)
  soldCount       Int      @default(0)
  objectType      String   @default("Resident Complex")
  propertyName    String?
  currency        String   @default("Rubels")
  region          String?
  area            String?
  city            String?
  developerBrand  String?
  website         String?
  banks           String?
  infrastructure  String?
  salesDepartment String?
  coverImage      String?
  documents       Json       @default("[]")
  fedLaw214       Boolean  @default(false)
  type            String   @default("object") // "category" | "object"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  unitLayouts UnitLayout[]
}

model ObjectType {
  id        String   @id @default(cuid())
  name      String
  title     String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UnitLayout {
  id                          String      @id @default(cuid())
  title                       String
  name                        String
  slug                        String      @unique
  floor                       Int
  number                      Int?
  totalArea                   Float
  internalArea                Float
  balconyArea                 Float?
  prices                      Json         @default("{}")
  completionYear              Int
  numberOfFloors              Json
  similarApartmentIds         String[]
  mainImage                   Json?
  gallery                     Json[]
  documents                   Json[]
  location                    Json?
  categoryId                  String
  category                    Category    @relation(fields: [categoryId], references: [id])
  roomOptionId                String?
  roomOption                  RoomOption? @relation(fields: [roomOptionId], references: [id])
  viewOptionId                String?
  viewOption                  ViewOption? @relation(fields: [viewOptionId], references: [id])
  statusOptionId              String?
  statusOption                StatusOption? @relation(fields: [statusOptionId], references: [id])
  lcd                         String?
  typeOfBuilding              String?
  defaultPropertyType         String?
  constructionStage           String?
  startOfConstruction         Json?
  completionOfConstruction    Json?
  startOfSales                Json?
  endOfSales                  Json?
  salesOffice                 String?
  contractAddress             String?
  street                      String?
  houseNumber                 String?
  deadlineForCommissioning    DateTime?
  landCadastralNumber         String?
  showroomAvailability        String?
  renovation                  String?
  wallMaterial                String?
  description                 String?
  ownerId                     String?
  owner                       Owner?      @relation(fields: [ownerId], references: [id])
  heatingTypeIds              String[]    @default([])
  attributeIds                String[]    @default([])
  locationTitle               String?
  locationUrl                 String?
  archived                    Boolean     @default(false)
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
}

model RoomOption {
  id        String   @id @default(cuid())
  name      String
  title     String
  type      String   @default("off-plan") // "resale" | "off-plan"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]

  @@unique([name, type])
}

model ViewOption {
  id        String       @id @default(cuid())
  name      String       @unique
  title     String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  unitLayouts UnitLayout[]
}

model Currency {
  id              String           @id @default(cuid())
  name            String           @unique
  title           String
  value           String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  apartmentPrices ApartmentPrice[]
}

model StatusOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]
}

model LcdOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TypeOfBuildingOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyTypeOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConstructionStageOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesOfficeOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HouseMaterialOption {
  id        String   @id @default(cuid())
  value     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Resale Models ───────────────────────────────────────────

model ApartmentType {
  id        String   @id @default(cuid())
  name      String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apartments Apartment[]
}

model Owner {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  profession  String?
  phoneNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apartments  Apartment[]
  unitLayouts UnitLayout[]
}

model Attribute {
  id        String   @id @default(cuid())
  name      String
  title     String
  value     String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Request {
  id          String   @id @default(cuid())
  fullName    String
  phoneNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Apartment {
  id              String        @id @default(cuid())
  name            String?
  title           String
  slug            String        @unique
  description     String?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  canonicalUrl    String?
  seoImage        String?
  image           String?
  coverImage      String?
  gallery         Json[]
  priceTotal      Float         @default(0)
  priceByArea     Float         @default(0)
  roomCount       Int
  area            Float
  netArea         Float?
  grossArea       Float?
  livingArea      Float?
  kitchenArea     Float?
  balconyArea     Float?
  floorFrom       Int
  floorTo         Int
  bathroomCount   Int?
  purpose         String        @default("sale")
  region          String?
  city            String?
  locationTitle   String?
  locationUrl     String?
  renovation      String?
  parking         Boolean?
  buildingAge     Int?
  furnishing      String?
  elevator        Boolean?
  ceilingHeight   Float?
  kitchenSize     Float?
  wallMaterial    String?
  heatingTypeIds  String[]      @default([])
  viewOptionIds   String[]      @default([])
  attributeIds    String[]
  requestIds      String[]
  status          String        @default("active")
  apartmentTypeId String
  apartmentType   ApartmentType  @relation(fields: [apartmentTypeId], references: [id])
  ownerId         String?
  owner           Owner?         @relation(fields: [ownerId], references: [id])
  prices          ApartmentPrice[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model LocationOption {
  id        String   @id @default(cuid())
  type      String
  name      String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, name])
}

model HeatingTypeOption {
  id        String   @id @default(cuid())
  name      String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApartmentPrice {
  id          String   @id @default(cuid())
  apartmentId String
  currencyId  String
  priceTotal  Float
  priceByArea Float
  currency    Currency @relation(fields: [currencyId], references: [id])
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, currencyId])
}
