generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  title     String
  name      String
  slug      String   @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]
}

model UnitLayout {
  id                  String      @id @default(cuid())
  title               String
  name                String
  slug                String      @unique
  floor               Int
  number              Int?
  totalArea           Float
  internalArea        Float
  balconyArea         Float?
  prices              Json         @default("{}")
  completionYear      Int
  numberOfFloors      Json
  similarApartmentIds String[]
  mainImage           Json?
  gallery             Json[]
  documents           Json[]
  location            Json?
  categoryId          String
  category            Category    @relation(fields: [categoryId], references: [id])
  roomOptionId        String?
  roomOption          RoomOption? @relation(fields: [roomOptionId], references: [id])
  viewOptionId        String?
  viewOption          ViewOption? @relation(fields: [viewOptionId], references: [id])
  statusOptionId      String?
  statusOption        StatusOption? @relation(fields: [statusOptionId], references: [id])
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model RoomOption {
  id        String   @id @default(cuid())
  value     String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]
}

model ViewOption {
  id        String       @id @default(cuid())
  value     String       @unique
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  unitLayouts UnitLayout[]
}

model Currency {
  id              String           @id @default(cuid())
  name            String           @unique
  value           String           @unique
  order           Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  apartmentPrices ApartmentPrice[]
}

model StatusOption {
  id        String   @id @default(cuid())
  value     String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unitLayouts UnitLayout[]
}

// ─── Resale Models ───────────────────────────────────────────

model ApartmentType {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apartments Apartment[]
}

model Owner {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  profession  String?
  phoneNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apartments Apartment[]
}

model Attribute {
  id        String   @id @default(cuid())
  name      String
  title     String
  value     String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Request {
  id          String   @id @default(cuid())
  fullName    String
  phoneNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Apartment {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String?
  image           String?
  gallery         Json[]
  priceTotal      Float         @default(0)
  priceByArea     Float         @default(0)
  roomCount       Int
  area            Float
  floorFrom       Int
  floorTo         Int
  locationTitle   String?
  locationUrl     String?
  renovation      String?
  kitchenSize     Float?
  wallMaterial    String?
  attributeIds    String[]
  requestIds      String[]
  apartmentTypeId String
  apartmentType   ApartmentType  @relation(fields: [apartmentTypeId], references: [id])
  ownerId         String?
  owner           Owner?         @relation(fields: [ownerId], references: [id])
  prices          ApartmentPrice[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ApartmentPrice {
  id          String   @id @default(cuid())
  apartmentId String
  currencyId  String
  priceTotal  Float
  priceByArea Float
  currency    Currency @relation(fields: [currencyId], references: [id])
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, currencyId])
}

// ─── Pulse (Blog) Models ─────────────────────────────────────

model Author {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  title       String?
  avatar      String?
  description String?
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Keyword {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]
}

model PulseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  category        String
  date            DateTime  @default(now())
  coverImage      String?
  excerpt         String?
  authorId        String?
  author          Author?   @relation(fields: [authorId], references: [id])
  keywords        Keyword[]
  blocks          Json      @default("[]")
  metaTitle       String?
  metaDescription String?
  featured        Boolean   @default(false)
  published       Boolean   @default(false)
  headerPosition  String?   // null | "left" | "center" | "right"
  headerOrder     Int?      // sort order within the section
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
