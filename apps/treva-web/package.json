{
    "name": "treva-web",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "node ../../scripts/run-with-env.cjs .env.development next dev --port 10010",
        "build": "node --max-old-space-size=2048 ../../scripts/run-with-env.cjs .env.production next build",
        "start": "node ../../scripts/run-with-env.cjs .env.production next start -p 10010",
        "lint": "eslint --max-warnings 0",
        "check-types": "next typegen && tsc --noEmit"
    },
    "dependencies": {
        "@repo/shared": "*",
        "@repo/types": "*",
        "@repo/ui": "*",
        "@tailwindcss/postcss": "^4.2.2",
        "@tanstack/react-query": "^5.99.0",
        "clsx": "^2.1.1",
        "gsap": "^3.15.0",
        "lucide-react": "^1.16.0",
        "next": "16.2.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-icons": "^5.6.0",
        "swiper": "^12.1.4",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@repo/eslint-config": "*",
        "@repo/typescript-config": "*",
        "@types/node": "^22.15.3",
        "@types/react": "19.2.2",
        "@types/react-dom": "19.2.2",
        "eslint": "^9.39.1",
        "typescript": "5.9.2"
    }
