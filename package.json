{
    "name": "treva-platform",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "start": "npm --prefix apps/treva-web start",
        "dev": "turbo run dev",
        "api:db:dev": "npm --prefix apps/treva-api run db:dev",
        "api:db:deploy": "npm --prefix apps/treva-api run db:deploy",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types"
    },
    "devDependencies": {
        "prettier": "^3.7.4",
        "turbo": "^2.9.6",
        "typescript": "5.9.2"
    },
    "engines": {
        "node": ">=18"
    },
    "packageManager": "npm@11.6.2",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "dependencies": {
        "gsap": "^3.15.0",
        "lucide-react": "^1.14.0"
    }
}
